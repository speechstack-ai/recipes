{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://speechstack.com/schemas/recipe.schema.json",
  "title": "Speechstack Recipe",
  "description": "Schema for a voice AI agent recipe in the Speechstack directory.",
  "type": "object",
  "required": [
    "id",
    "slug",
    "title",
    "description",
    "framework",
    "use_case",
    "industry",
    "languages",
    "pipeline",
    "contributor",
    "source",
    "created_at",
    "updated_at",
    "license"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Lowercase, hyphen-separated identifier. Must match the filename (minus .json)."
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "URL-friendly slug. Usually identical to id, but can diverge for SEO reasons."
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 120,
      "description": "Human-readable title, e.g. 'Automated Dental Clinic Scheduling Assistant'."
    },
    "description": {
      "type": "string",
      "minLength": 30,
      "maxLength": 500,
      "description": "One-paragraph description of what the agent does and the problem it solves."
    },
    "framework": {
      "type": "string",
      "description": "The primary voice agent framework. Must be in data/vendors.json under 'framework'."
    },
    "use_case": {
      "type": "string",
      "description": "The primary use case. Must be a value from data/use-cases.json."
    },
    "industry": {
      "type": "string",
      "description": "The primary industry. Must be a value from data/industries.json."
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
        "description": "BCP-47 language tag, e.g. 'en-US', 'es', 'fr-CA'."
      }
    },
    "pipeline": {
      "type": "object",
      "required": ["stt", "llm", "tts", "telephony"],
      "additionalProperties": false,
      "properties": {
        "stt": {
          "type": "string",
          "description": "Speech-to-text vendor and model, e.g. 'Deepgram Nova-3'."
        },
        "llm": {
          "type": "string",
          "description": "LLM vendor and model, e.g. 'Claude Sonnet 4.5' or 'GPT-4o'."
        },
        "tts": {
          "type": "string",
          "description": "Text-to-speech vendor and model, e.g. 'Cartesia Sonic-3' or 'ElevenLabs Flash v2.5'."
        },
        "telephony": {
          "type": ["string", "null"],
          "description": "Telephony provider, e.g. 'Twilio SIP'. Null for web-only agents."
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latency_p50_ms": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Median round-trip latency in milliseconds."
        },
        "latency_p95_ms": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "95th percentile round-trip latency in milliseconds."
        },
        "latency_display": {
          "type": ["string", "null"],
          "description": "Human-readable latency for display, e.g. '~500-700ms'."
        },
        "cost_per_minute_usd_min": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Lower bound of estimated $/minute."
        },
        "cost_per_minute_usd_max": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Upper bound of estimated $/minute."
        },
        "cost_display": {
          "type": ["string", "null"],
          "description": "Human-readable cost for display, e.g. '$0.09 - $0.14'."
        }
      }
    },
    "raw_prompt": {
      "type": ["string", "null"],
      "description": "Inline prompt for short prompts (<200 words). Use prompt_file for longer prompts."
    },
    "prompt_file": {
      "type": ["string", "null"],
      "pattern": "^prompts/[a-z0-9]+(-[a-z0-9]+)*\\.md$",
      "description": "Relative path to a Markdown file in recipes/prompts/ containing the full prompt."
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "description": "Free-form configuration object. Common fields include voice_id, temperature, barge_in, tools.",
      "properties": {
        "voice_id": { "type": ["string", "null"] },
        "temperature": { "type": ["number", "null"], "minimum": 0, "maximum": 2 },
        "barge_in": { "type": ["boolean", "null"] },
        "interruption_threshold_ms": { "type": ["integer", "null"], "minimum": 0 },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "parameters": { "type": "object" }
            }
          }
        }
      }
    },
    "github_source_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "URL to the public source repository or specific file/folder."
    },
    "demo_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "URL to a live demo, video walkthrough, or interactive sandbox."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
      "description": "Free-form tags for filtering and SEO. Use lowercase, hyphen-separated."
    },
    "contributor": {
      "type": "object",
      "required": ["github"],
      "additionalProperties": false,
      "properties": {
        "github": { "type": "string", "minLength": 1 },
        "twitter": { "type": ["string", "null"] },
        "name": { "type": ["string", "null"] },
        "website": { "type": ["string", "null"], "format": "uri" }
      }
    },
    "source": {
      "type": "string",
      "enum": [
        "vendor_showcase",
        "github_discovery",
        "youtube_tutorial",
        "blog_post",
        "web_submission",
        "direct_pr",
        "editorial"
      ],
      "description": "How this recipe entered the directory. Useful for analytics."
    },
    "verified": {
      "type": "boolean",
      "default": false,
      "description": "True if a Speechstack editor manually tested or otherwise confirmed this recipe."
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Editorial pick. Drives homepage placement."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the recipe was first published."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last update."
    },
    "license": {
      "type": "string",
      "enum": ["MIT", "Apache-2.0", "BSD-2-Clause", "BSD-3-Clause", "CC-BY-4.0", "Unlicense", "Proprietary"],
      "description": "License of the recipe code/content as released by its author."
    },
    "notes": {
      "type": ["string", "null"],
      "description": "Editor notes or supplementary context. Optional."
    }
  }
}
