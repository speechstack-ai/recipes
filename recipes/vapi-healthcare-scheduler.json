{
  "id": "vapi-healthcare-scheduler",
  "slug": "vapi-healthcare-scheduler",
  "title": "Automated Dental Clinic Scheduling Assistant",
  "description": "An inbound phone receptionist that handles booking, rescheduling, and cancellations for dental clinics. Integrates directly with Cal.com and common Practice Management Systems to check availability, hold appointments, and update patient records without human intervention.",
  "framework": "Vapi",
  "use_case": "scheduling",
  "industry": "healthcare",
  "languages": ["en-US"],
  "pipeline": {
    "stt": "Deepgram Nova-3",
    "llm": "Claude Sonnet 4.5",
    "tts": "Cartesia Sonic-3",
    "telephony": "Twilio SIP"
  },
  "metrics": {
    "latency_p50_ms": 600,
    "latency_p95_ms": 900,
    "latency_display": "~500-700ms",
    "cost_per_minute_usd_min": 0.09,
    "cost_per_minute_usd_max": 0.14,
    "cost_display": "$0.09 - $0.14"
  },
  "raw_prompt": null,
  "prompt_file": "prompts/vapi-healthcare-scheduler.md",
  "config": {
    "voice_id": "cartesia-sherlock-9626c31c",
    "temperature": 0.1,
    "barge_in": true,
    "interruption_threshold_ms": 200,
    "tools": [
      {
        "name": "check_calendar_availability",
        "description": "Queries Cal.com for appointment availability across providers and time slots.",
        "parameters": {
          "type": "object",
          "properties": {
            "provider_id": { "type": "string" },
            "date_range_start": { "type": "string", "format": "date" },
            "date_range_end": { "type": "string", "format": "date" }
          },
          "required": ["date_range_start", "date_range_end"]
        }
      },
      {
        "name": "book_appointment",
        "description": "Books an appointment slot in Cal.com and creates a matching record in the PMS.",
        "parameters": {
          "type": "object",
          "properties": {
            "slot_id": { "type": "string" },
            "patient_name": { "type": "string" },
            "patient_phone": { "type": "string" },
            "appointment_type": { "type": "string" }
          },
          "required": ["slot_id", "patient_name", "patient_phone"]
        }
      },
      {
        "name": "cancel_or_reschedule",
        "description": "Cancels or reschedules an existing appointment by appointment ID.",
        "parameters": {
          "type": "object",
          "properties": {
            "appointment_id": { "type": "string" },
            "action": { "type": "string", "enum": ["cancel", "reschedule"] },
            "new_slot_id": { "type": "string" }
          },
          "required": ["appointment_id", "action"]
        }
      }
    ]
  },
  "github_source_url": "https://github.com/VapiAI/examples/tree/main/assistants/healthcare-scheduling",
  "demo_url": null,
  "tags": [
    "dental",
    "calendar-integration",
    "barge-in",
    "twilio-sip",
    "calcom",
    "tool-calling"
  ],
  "contributor": {
    "github": "speechstack",
    "twitter": "speechstack",
    "name": "Speechstack Team",
    "website": "https://speechstack.com"
  },
